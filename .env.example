# Directory API
DIRECTORY_API_PORT=3001
APF_ADMIN_USERNAME=admin
APF_ADMIN_PASSWORD=

# Frontend API target
REACT_APP_DIRECTORY_API=http://localhost:3001
REACT_APP_ARCHIVE_ROOT_PATH=/B2BP/UserData/archives

# Database source
# Supported values: json, mssql, mysql, postgres
DIRECTORY_DB_CLIENT=json
DIRECTORY_DB_HOST=
DIRECTORY_DB_PORT=
DIRECTORY_DB_NAME=
DIRECTORY_DB_USER=
DIRECTORY_DB_PASSWORD=
DIRECTORY_DB_SCHEMA=
DIRECTORY_DB_TABLE=directory_entries
DIRECTORY_DB_SSL=false
DIRECTORY_DB_ENCRYPT=false
DIRECTORY_DB_TRUST_SERVER_CERTIFICATE=true
DIRECTORY_DB_ID_COLUMN=id
DIRECTORY_DB_BU_COLUMN=bu
DIRECTORY_DB_TYPE_COLUMN=type
DIRECTORY_DB_LABEL_COLUMN=label
DIRECTORY_DB_URL_COLUMN=url
DIRECTORY_DB_BACKUP_COLUMN=backup
DIRECTORY_DB_UPDATED_AT_COLUMN=updated_at

# Target host used when a link is stored as a relative path
DIRECTORY_TARGET_PROTOCOL=http
DIRECTORY_TARGET_HOST=frb2bcdu01.groupecat.com
DIRECTORY_TARGET_PORT=8000

# Optional HTTP proxy used by the preview API to reach remote directories
DIRECTORY_PROXY_PROTOCOL=http
DIRECTORY_PROXY_HOST=
DIRECTORY_PROXY_PORT=80
DIRECTORY_PROXY_USERNAME=
DIRECTORY_PROXY_PASSWORD=
DIRECTORY_PROXY_BYPASS_HOSTS=

# Unix archive source used by the file browser and dynamic search
ARCHIVE_SERVER_HOST=frb2bcdu01.groupecat.com
ARCHIVE_SERVER_PORT=22
ARCHIVE_SERVER_USERNAME=
ARCHIVE_SERVER_PASSWORD=
ARCHIVE_SERVER_ROOT_PATH=/B2BP/UserData/archives
